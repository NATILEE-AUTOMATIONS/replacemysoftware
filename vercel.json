{
  "outputDirectory": ".",
  "functions": {
    "api/contact.js": {
      "runtime": "@vercel/node@5"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
